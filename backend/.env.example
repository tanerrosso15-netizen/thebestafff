# PQP Affiliate Panel — ortam değişkenleri (kopyala: .env)

# Güvenlik
SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Veritabanı — kalıcı data/ klasöründe (Docker volume ile korunur)
DATABASE_URL=sqlite:///./data/pqp_affiliate.db

# Master admin (ilk açılışta oluşturulur)
MASTER_ADMIN_NAME=ADMIN
MASTER_ADMIN_EMAIL=admin@panel.com
MASTER_ADMIN_PASSWORD=ordinarman34.

# Marka / panel
BRAND_NAME=PQP
PANEL_TITLE=Admin
SITE_NAME=CASINOPERA

# Referans linki kök adresi
REFERRAL_BASE_URL=https://www.casinopera.com/

# CasinoOpera / Lynon backoffice entegrasyonu
CASINOPERA_ENABLED=true
CASINOPERA_BASE_URL=https://backoffice.casinopera.com/api/user/api/v1.0
CASINOPERA_SITE_ID=125
CASINOPERA_SESSION_COOKIE=
CASINOPERA_SESSION_FILE=data/casinopera.cookie

# Periyodik senkronizasyon (saniye)
SYNC_INTERVAL_SECONDS=300
SYNC_ENABLED=true

# Demo verisi — production'da false
SEED_DEMO_DATA=false

# CORS — kendi domaininizi ekleyin (virgülle ayırın)
# Örnek: https://aff.example.com,https://thebestaff.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# Ortam değişkenleri — kopyala: cp .env.example .env

# Güvenlik (production'da mutlaka değiştirin)
SECRET_KEY=replace-with-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Veritabanı
DATABASE_URL=sqlite:///./data/affiliate.db

# İlk admin hesabı
MASTER_ADMIN_NAME=Admin
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=change-me-on-first-setup

# Marka / panel (panelden de düzenlenebilir)
BRAND_NAME=Affiliate Panel
PANEL_TITLE=Admin
SITE_NAME=Platform

# Referans linki kök adresi
REFERRAL_BASE_URL=https://your-platform.example/

# Platform backoffice entegrasyonu
CASINOPERA_ENABLED=true
CASINOPERA_BASE_URL=https://backoffice.example/api/v1.0
CASINOPERA_SITE_ID=1
CASINOPERA_SESSION_COOKIE=
CASINOPERA_SESSION_FILE=data/platform.cookie

# Senkronizasyon — varsayılan: her gece 00:00 (Europe/Istanbul)
SYNC_MODE=cron
SYNC_CRON_HOUR=0
SYNC_CRON_MINUTE=0
SYNC_TIMEZONE=Europe/Istanbul
SYNC_INTERVAL_SECONDS=300
SYNC_ENABLED=true
SEED_DEMO_DATA=false

# Supabase PostgreSQL (production)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# CORS — kendi domainlerinizi virgülle ekleyin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
